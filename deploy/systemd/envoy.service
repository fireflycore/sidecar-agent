[Unit]
Description=Envoy Proxy
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/envoy -c /etc/firefly/sidecar-agent/envoy-bootstrap.yaml --log-level info
Restart=always
RestartSec=3
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
